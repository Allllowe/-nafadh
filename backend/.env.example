# Port the Express server listens on
PORT=5000

# Domain used for generated temporary email addresses (e.g. abc123@nafadh.local)
INBOX_DOMAIN=nafadh.local

# How long a temporary inbox lives before it expires, in minutes
INBOX_TTL_MINUTES=20

# Comma-separated list of origins allowed to call this API.
# "*" (the default if you skip this) is fine for local development.
# Replace with your real frontend origin(s) before deploying.
CORS_ORIGIN=*

# Shared secret that inbound-mail providers (Mailgun, SendGrid Inbound
# Parse, a custom SMTP receiver, etc.) must send to push a real message
# into an inbox via POST /api/inbox/:address/messages
INBOUND_WEBHOOK_SECRET=change-me-to-a-long-random-string
